#define DEF_GUUS_VERSION_MAJOR 12
#define DEF_GUUS_VERSION_MINOR 0
#define DEF_GUUS_VERSION_PATCH 0

#define GUUS_STRINGIFY2(val) #val
#define GUUS_STRINGIFY(val) GUUS_STRINGIFY2(val)
#define DEF_GUUS_VERSION GUUS_STRINGIFY(DEF_GUUS_VERSION_MAJOR) "." GUUS_STRINGIFY(DEF_GUUS_VERSION_MINOR) "." GUUS_STRINGIFY(DEF_GUUS_VERSION_PATCH)

#define DEF_GUUS_VERSION_TAG "@VERSIONTAG@"
#define DEF_GUUS_RELEASE_NAME "Victory"
#define DEF_GUUS_VERSION_FULL DEF_GUUS_VERSION "-" DEF_GUUS_VERSION_TAG

#include "version.h"

const int GUUS_VERSION_MAJOR = DEF_GUUS_VERSION_MAJOR;
const int GUUS_VERSION_MINOR = DEF_GUUS_VERSION_MINOR;
const int GUUS_VERSION_PATCH = DEF_GUUS_VERSION_PATCH;

const char* const GUUS_VERSION_TAG = DEF_GUUS_VERSION_TAG;
const char* const GUUS_VERSION = DEF_GUUS_VERSION;
const char* const GUUS_RELEASE_NAME = DEF_GUUS_RELEASE_NAME;
const char* const GUUS_VERSION_FULL = DEF_GUUS_VERSION_FULL;
